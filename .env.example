# Unraid server IP address
UNRAID_IP=192.168.1.100

# Transmission RPC port (default: 9091)
TRANSMISSION_PORT=9091

# Docker TCP API port (default: 2375)
DOCKER_PORT=2375

# Docker container name for Transmission
CONTAINER_NAME=transmission-vpn

# How often to check Transmission health (milliseconds, default: 5 minutes)
CHECK_INTERVAL_MS=300000

# How long to wait after restart before re-enabling torrents (milliseconds, default: 10 minutes)
RECOVERY_WAIT_MS=600000

# URL used to verify network connectivity
NETWORK_CHECK_URL=http://1.1.1.1

# How long to wait between restart poll attempts (milliseconds, default: 10 seconds)
RESTART_POLL_INTERVAL_MS=10000

# How many times to poll for Transmission to come back up after restart
RESTART_MAX_ATTEMPTS=30

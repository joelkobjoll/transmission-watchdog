# Unraid server IP address
UNRAID_IP=192.168.1.100

# Docker TCP API port (default: 2375 — enable in Unraid Settings → Docker → Enable TCP)
DOCKER_PORT=2375

# Container names
CONTAINER_NAME=transmission-vpn
VPN_CONTAINER_NAME=wireguard-pia

# Transmission RPC port
TRANSMISSION_PORT=9091


# Path to the forwarded port file inside the VPN container
VPN_PORT_FILE_PATH=/pia-shared/port.dat

# Enable or disable VPN port forwarding logic (true/false)
VPN_PORT_FORWARDING_ENABLED=true

# Max poll attempts waiting for VPN tunnel to establish (~10 min @ 10s intervals)
VPN_CONNECT_TIMEOUT_ATTEMPTS=60

# Health check frequency (milliseconds) — default 5 minutes
CHECK_INTERVAL_MS=300000

# Wait after restart before re-enabling torrents (milliseconds) — default 10 minutes
RECOVERY_WAIT_MS=600000

# Poll interval while waiting for containers to come back (milliseconds) — default 10 seconds
RESTART_POLL_INTERVAL_MS=10000

# Max polls for Transmission RPC to come back after restart (~5 min window)
RESTART_MAX_ATTEMPTS=30

# Consecutive external RPC failures before investigating further
TX_HEALTH_RETRIES=3

# Wait between TX health retries (milliseconds) — default 2 minutes
TX_HEALTH_RETRY_INTERVAL_MS=120000

# Timeout for Docker exec operations (milliseconds) — default 30 seconds
EXEC_TIMEOUT_MS=30000

# URL used to verify local internet connectivity
NETWORK_CHECK_URL=http://1.1.1.1


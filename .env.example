# Unraid server IP address
UNRAID_IP=192.168.1.100

# Docker TCP API port (default: 2375 — enable in Unraid Settings → Docker → Enable TCP)
DOCKER_PORT=2375

# ─── Client selection ─────────────────────────────────────────────────────────
# Which torrent clients to monitor (comma-separated).
# Valid values: transmission, qbittorrent
# Leave empty for VPN-only monitoring (no torrent client).
# Examples:
#   TORRENT_CLIENTS=transmission              ← Transmission only (default)
#   TORRENT_CLIENTS=qbittorrent              ← qBittorrent only
#   TORRENT_CLIENTS=transmission,qbittorrent ← both
#   TORRENT_CLIENTS=                         ← VPN-only, no torrent client
TORRENT_CLIENTS=transmission

# ─── VPN container ────────────────────────────────────────────────────────────
VPN_CONTAINER_NAME=wireguard-pia

# Path to the forwarded port file inside the VPN container
VPN_PORT_FILE_PATH=/pia-shared/port.dat

# Enable or disable VPN port forwarding logic (true/false)
# Set to false when using gluetun or any VPN that does not write a port file
VPN_PORT_FORWARDING_ENABLED=true

# Max poll attempts waiting for VPN tunnel to establish (~10 min @ 10s intervals)
VPN_CONNECT_TIMEOUT_ATTEMPTS=60

# ─── Transmission ─────────────────────────────────────────────────────────────
# (only used when "transmission" is in TORRENT_CLIENTS)

# Docker container name for Transmission
CONTAINER_NAME=transmission-vpn

# Transmission RPC port
TRANSMISSION_PORT=9091

# ─── qBittorrent ──────────────────────────────────────────────────────────────
# (only used when "qbittorrent" is in TORRENT_CLIENTS)

# Docker container name for qBittorrent
QBITTORRENT_CONTAINER_NAME=qbittorrent

# qBittorrent Web UI port
# Note: uses the v5.0+ API endpoints (/torrents/stop, /torrents/start).
#       For qBittorrent v4.x, change those calls to /torrents/pause and /torrents/resume.
QBITTORRENT_PORT=8080

# qBittorrent Web UI credentials (leave blank if WebUI auth is disabled)
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# ─── Timing & polling ─────────────────────────────────────────────────────────

# Health check frequency (milliseconds) — default 5 minutes
CHECK_INTERVAL_MS=300000

# Wait after restart before re-enabling torrents (milliseconds) — default 10 minutes
RECOVERY_WAIT_MS=600000

# Poll interval while waiting for containers to come back (milliseconds) — default 10 seconds
RESTART_POLL_INTERVAL_MS=10000

# Max polls for client API to come back after restart (~5 min window)
RESTART_MAX_ATTEMPTS=30

# Consecutive external API failures before investigating further
TX_HEALTH_RETRIES=3

# Wait between health retries (milliseconds) — default 2 minutes
TX_HEALTH_RETRY_INTERVAL_MS=120000

# Timeout for Docker exec operations (milliseconds) — default 30 seconds
EXEC_TIMEOUT_MS=30000

# URL used to verify local internet connectivity
NETWORK_CHECK_URL=http://1.1.1.1

